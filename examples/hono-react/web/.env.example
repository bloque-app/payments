# Publishable key — used if not using the Hono API backend for init
VITE_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional — client secret JWT (from bloque.checkout.create on your backend)
# VITE_CLIENT_SECRET=cs_...

# Optional — custom hosted checkout URL
# VITE_CHECKOUT_URL=http://localhost:3000/checkout

# Optional — sandbox or production (defaults to sandbox for local dev)
# VITE_BLOQUE_MODE=sandbox

# Optional — 3DS sandbox scenario (challenge_v2, no_challenge_success, etc.)
# VITE_THREE_DS_AUTH_TYPE=challenge_v2
